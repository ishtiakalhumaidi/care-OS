<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="color-scheme" content="light" />
<title>Account Provisioned: CareOS</title>
</head>
<body style="margin:0; padding:0; background-color:#F4F4F5; font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; -webkit-font-smoothing: antialiased;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F4F4F5; padding:60px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="480" cellpadding="0" cellspacing="0" style="max-width:480px; width:100%; background-color:#FFFFFF; border:1px solid #E4E4E7; border-radius:12px; overflow:hidden; box-shadow:0 4px 6px -1px rgba(0,0,0,0.05);">

          <!-- Header -->
          <tr>
            <td style="background-color:#09090B; padding:32px 40px; border-bottom:1px solid #27272A;">
              <table role="presentation" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="vertical-align:middle;">
                    <img src="<%= logoUrl %>" width="32" height="32" alt="CareOS" style="display:block; border:0; outline:none;" />
                  </td>
                  <td style="vertical-align:middle; padding-left:10px;">
                    <span style="font-size:18px; font-weight:700; color:#FFFFFF; letter-spacing:-0.3px;">CareOS</span>
                  </td>
                </tr>
              </table>
              <p style="margin:16px 0 0 0; font-family: 'SFMono-Regular', Consolas, 'Courier New', monospace; font-size:11px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; color:#A1A1AA;">
                Account Provisioned
              </p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:40px;">
              <h1 style="margin:0 0 12px 0; font-size:20px; line-height:1.4; color:#18181B; font-weight:600; letter-spacing:-0.4px;">
                Welcome, <%= name %>
              </h1>
              <p style="margin:0 0 28px 0; font-size:14px; line-height:1.6; color:#52525B;">
                Your administrative center account has been provisioned. Authenticate using the temporary credentials provided below. A permanent password configuration is required upon initial login.
              </p>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #E4E4E7; border-radius:8px; margin-bottom:28px; overflow:hidden;">
                <tr>
                  <td style="padding:16px 20px; background-color:#FAFAFA; border-bottom:1px solid #E4E4E7;">
                    <p style="margin:0 0 4px 0; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; color:#71717A;">
                      System Email
                    </p>
                    <p style="margin:0; font-size:14px; color:#18181B; font-family: 'SFMono-Regular', Consolas, 'Courier New', monospace;">
                      <%= email %>
                    </p>
                  </td>
                </tr>
                <tr>
                  <td style="padding:16px 20px; background-color:#FFFFFF;">
                    <p style="margin:0 0 4px 0; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; color:#71717A;">
                      Temporary Key
                    </p>
                    <p style="margin:0; font-size:16px; font-weight:600; color:#18181B; font-family: 'SFMono-Regular', Consolas, 'Courier New', monospace; letter-spacing:0.5px;">
                      <%= tempPassword %>
                    </p>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="left">
                    <a href="<%= loginUrl %>" style="display:inline-block; background-color:#18181B; color:#FFFFFF; font-size:14px; font-weight:500; text-decoration:none; padding:12px 24px; border-radius:6px; border:1px solid #000000;">
                      Authenticate to CareOS &rarr;
                    </a>
                  </td>
                </tr>
              </table>

              <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color:#F4F4F5; border-left:3px solid #71717A; padding:12px 16px; margin-top:32px;">
                <tr>
                  <td>
                    <p style="margin:0; font-size:13px; line-height:1.5; color:#52525B;">
                      <strong style="color:#18181B;">Security Notice:</strong> This key is restricted to <strong style="color:#18181B; font-weight:700;">single-use</strong> for your initial authentication.
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:24px 40px; background-color:#FAFAFA; border-top:1px solid #E4E4E7;">
              <p style="margin:0; font-size:12px; color:#A1A1AA; text-align:left; line-height:1.5;">
                CareOS System Infrastructure.<br />
                Automated transmission. Replies are not monitored.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>