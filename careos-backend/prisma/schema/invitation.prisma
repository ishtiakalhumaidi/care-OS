model Invitation {
  id          String       @id @default(uuid())
  email       String
  role        Role
  token       String       @unique
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Scoping data so we can auto-enroll user on click
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  classroomId String?

  @@index([token])
  @@index([email])
}