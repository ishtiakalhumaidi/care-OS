model Attendance {
  id            String    @id @default(uuid())
  childId       String
  child         Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  
  checkInTime   DateTime
  checkOutTime  DateTime?
  checkedInBy   String    
  checkedOutBy  String?
  
  syncedAt      DateTime  @default(now())
  
  @@index([childId, checkInTime])
}

model TimelineEvent {
  id            String    @id @default(uuid())
  childId       String
  child         Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  
  eventType     String    // "NAP", "MEAL", "BATHROOM", "NOTE"
  description   String?
  loggedBy      String    // Teacher ID
  loggedAt      DateTime  @default(now())
}