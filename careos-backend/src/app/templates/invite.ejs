<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>You've been invited to CareOS</title>
</head>
<body style="margin:0; padding:0; background-color:#F9FAFB; font-family: 'Segoe UI', Helvetica, Arial, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F9FAFB; padding:40px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="480" cellpadding="0" cellspacing="0" style="max-width:480px; width:100%; background-color:#FFFFFF; border:1px solid #E5E7EB; border-radius:16px; overflow:hidden;">

          <!-- Header -->
          <tr>
            <td style="padding:32px 32px 0 32px;">
              <table role="presentation" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="width:32px; height:32px; background-color:#4F46E5; border-radius:8px; text-align:center; vertical-align:middle;">
                    <span style="color:#F9FAFB; font-size:14px; font-weight:700; font-family: Georgia, 'Times New Roman', serif; line-height:32px;">C</span>
                  </td>
                  <td style="padding-left:10px;">
                    <span style="font-size:18px; font-weight:600; color:#111827; font-family: Georgia, 'Times New Roman', serif; letter-spacing:-0.3px;">CareOS</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:32px;">
              <p style="margin:0 0 4px 0; font-size:12px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; color:#4F46E5;">
                You're invited
              </p>
              <h1 style="margin:0 0 16px 0; font-size:22px; line-height:1.3; color:#111827; font-weight:600;">
                Join <%= tenantName %> on CareOS
              </h1>
              <p style="margin:0 0 4px 0; font-size:14px; line-height:1.6; color:#6B7280;">
                You've been invited to join as a
                <span style="display:inline-block; background-color:#EEF2FF; color:#4F46E5; font-size:12px; font-weight:600; padding:3px 10px; border-radius:999px; text-transform:capitalize;">
                  <%= role %>
                </span>
              </p>
              <p style="margin:16px 0 28px 0; font-size:14px; line-height:1.6; color:#6B7280;">
                Click below to set up your account. This invite link is valid for 7 days.
              </p>

              <!-- CTA -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center">
                    <a href="<%= inviteLink %>" style="display:inline-block; background-color:#FF7F50; color:#1F1300; font-size:14px; font-weight:600; text-decoration:none; padding:14px 32px; border-radius:10px;">
                      Accept Invitation &rarr;
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin:24px 0 0 0; font-size:12px; line-height:1.6; color:#9CA3AF; word-break:break-all;">
                Or copy this link into your browser:<br />
                <a href="<%= inviteLink %>" style="color:#4F46E5; text-decoration:none;"><%= inviteLink %></a>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:24px 32px; background-color:#F9FAFB; border-top:1px solid #E5E7EB;">
              <p style="margin:0; font-size:12px; color:#9CA3AF; text-align:center; line-height:1.6;">
                CareOS · Childcare Management, Engineered for Peace of Mind.<br />
                If you weren't expecting this invite, you can safely ignore this email.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
